# Veda Advisors — environment variable template
# Copy this file to `.env` (local dev) or set the same keys in your Vercel project settings.
# `.env` is gitignored — never commit real secrets.

# ─────────────────────────────────────────────────────────────
# Database (Prisma) — REQUIRED for build and any DB-using route
# Local SQLite example:
#   file:./db/custom.db
# Production (Vercel): use a real Postgres URL, e.g.:
#   postgresql://user:pass@host:port/dbname?schema=public
# ─────────────────────────────────────────────────────────────
DATABASE_URL="file:./db/custom.db"

# ─────────────────────────────────────────────────────────────
# Health-check endpoint (/api) — OPTIONAL
# Set STARTED_AT to the deploy timestamp for cold-start tracking.
# VERCEL_ENV and VERCEL_REGION are auto-populated by Vercel.
# ─────────────────────────────────────────────────────────────
# STARTED_AT="2026-06-27T00:00:00Z"

# ─────────────────────────────────────────────────────────────
# Supabase — OPTIONAL (used by /stage0 form)
# Currently the values are inlined in src/app/stage0/page.tsx because
# only the public anon key is needed (safe to expose). Move them here
# if you want to switch projects without redeploying code.
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ─────────────────────────────────────────────────────────────
# NextAuth — OPTIONAL (next-auth is installed but not yet wired up)
# Required only when authentication is added in a future task.
# Generate a secret with: `openssl rand -base64 32`
# ─────────────────────────────────────────────────────────────
# NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# NEXTAUTH_URL="http://localhost:3000"
