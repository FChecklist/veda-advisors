{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Artifact Registry Entry",
  "type": "object",
  "required": ["id","module","status"],
  "properties": {
    "id": {"type":"string"},
    "name": {"type":"string"},
    "description": {"type":"string"},
    "module": {"type":"string"},
    "status": {"type":"string","enum":["pending","implemented","tested","deployed","deprecated"]},
    "related_to": {"type":"object"}
  }
}
