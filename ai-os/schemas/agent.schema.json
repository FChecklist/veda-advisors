{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Agent Definition",
  "type": "object",
  "required": ["id","role","type","status","responsibilities","reports_to"],
  "properties": {
    "id": {"type":"string"},
    "role": {"type":"string"},
    "type": {"type":"string","enum":["orchestrator","developer","designer","tester","quality","management","product","specialist"]},
    "status": {"type":"string","enum":["active","available","busy","blocked","offline"]},
    "responsibilities": {"type":"array","items":{"type":"string"},"minItems":1},
    "reports_to": {"type":"string"}
  }
}
